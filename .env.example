# ---- Microsoft Graph app (Entra ID app registration) ----
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=

# ---- Identity URN namespace embedded in client cert SAN URIs ----
# Must match what your PKI issues certs with, and must match on both
# freeradius (verify-client-cert.sh) and the helper.
URN_PREFIX=urn:example.com

# ---- FreeRADIUS: clients + shared secret ----
RADIUS_CLIENT_NAME=wifi_infra
RADIUS_CLIENT_IPADDRS=10.0.0.0/24
RADIUS_SHARED_SECRET=
FREERADIUS_DEBUG=false

# ---- FreeRADIUS: VLAN assignment ----
# Each of the four VLANs below can be independently enabled and given its own
# 802.1Q tag. Medium (wifi vs wired) is determined from the NAS-Port-Type
# attribute the AP/switch sends (Wireless-802.11 vs Ethernet) - confirm your
# hardware actually sends it before relying on this.
#
# The helper's policy tier (access/untrust/reject - see intune-radius-helper's
# README for the rule engine that decides it) is checked per-request from
# post-auth via check-policy.sh. "Access" with no VLAN configured for the
# matching medium is a plain accept (no VLAN attribute). "Untrust" with no
# VLAN configured for the matching medium rejects instead of leaving an
# untrusted client on an unspecified network.
WIFI_ACCESS_VLAN_ENABLED=false
WIFI_ACCESS_VLAN_TAG=
WIFI_UNTRUST_VLAN_ENABLED=false
WIFI_UNTRUST_VLAN_TAG=

WIRED_ACCESS_VLAN_ENABLED=false
WIRED_ACCESS_VLAN_TAG=
WIRED_UNTRUST_VLAN_ENABLED=false
WIRED_UNTRUST_VLAN_TAG=

# ---- FreeRADIUS: client cert verification ----
# CN of the CA that issues client certs (checked against cert issuer)
EXPECTED_ISSUER_CN=
ENABLE_CRL_VERIFICATION=false

# ---- Helper: policy ----
# Declarative JSON ruleset (first-match-wins) deciding access/untrust/reject.
# Mount your own at ./config/policy.json (see docker-compose.yaml's
# intune-radius-helper volumes) - copy
# https://github.com/griefersutherland/intune-radius-helper/blob/main/policy.example.json
# as a starting point. If ./config/policy.json doesn't exist, the helper's
# built-in default ruleset is used. See that repo's README for the fact
# reference and rule schema.
POLICY_RULES_FILE=/config/policy.json

# Escape hatch: skip Graph/policy entirely and allow anything FreeRADIUS's
# own cert verification already accepted.
TRUST_CHAIN_FALLBACK=false

# ---- Helper: optional on-prem AD device lookup (LDAPS) ----
# Requires the device cert to also carry a
# `<URN_PREFIX>:onprem-sid:{{OnPremisesSecurityIdentifier}}` SAN URI (add this
# alongside entra-device-id in the Intune SCEP profile's SAN section - see
# "Client certs (device/user) via Intune SCEP" above). Populates
# ad_device_found/ad_device_enabled facts; the default policy doesn't
# reference them, so this alone changes nothing until your policy.json does.
AD_LDAP_ENABLED=false
AD_LDAP_SERVER=
AD_LDAP_PORT=636
AD_LDAP_USE_SSL=true
AD_LDAP_VERIFY_CERT=true
AD_LDAP_BIND_USERNAME=
AD_LDAP_BIND_PASSWORD=
AD_LDAP_BASE_DN=
AD_LDAP_TIMEOUT_SECONDS=10

# ---- Helper: Graph behavior ----
GRAPH_TIMEOUT_SECONDS=20
GRAPH_MAX_RETRIES=1

# ---- Helper: cache backend ----
CACHE_BACKEND=postgres_redis
LOCAL_CACHE_FIRST=true
LOCAL_CACHE_MAX_AGE_SECONDS=900

POSTGRES_DB=radius_cache
POSTGRES_USER=radius_app
POSTGRES_PASSWORD=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_CACHE_TTL_SECONDS=300

# ---- Helper: background cache refresh ----
LIVE_LOOKUP_CACHE_SECONDS=300
DEVICE_CACHE_REFRESH_SECONDS=900
USER_CACHE_REFRESH_ENABLED=true
USER_CACHE_REFRESH_SECONDS=1800
USER_CACHE_SOURCE=all

# ---- Helper: stale fallback ----
ALLOW_STALE_CACHE_ON_GRAPH_ERROR=true
MAX_STALE_CACHE_HOURS=24

# ---- Logs ----
INTUNE_AUTH_LOG=/logs/intune-auth.log
